{
  "name": "pishposh",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c blue,green \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:server": "npm run dev --workspace apps/server",
    "build": "concurrently -n web,server -c blue,green \"npm:build:web\" \"npm:build:server\"",
    "build:web": "npm run build --workspace apps/web",
    "build:server": "npm run build --workspace apps/server",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace apps/server",
    "db:seed": "npm run db:seed --workspace apps/server",
    "db:codegen": "npm run db:codegen --workspace apps/server",
    "db:setup": "npm run db:setup --workspace apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2"
  }
}
